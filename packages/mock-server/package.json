{
  "name": "@sigstore/mock-server",
  "version": "0.4.0",
  "private": "true",
  "description": "Sigstore Mock Server",
  "bin": {
    "server": "./bin/run"
  },
  "files": [
    "/bin",
    "/dist",
    "/oclif.manifest.json"
  ],
  "scripts": {
    "clean": "shx rm -rf dist",
    "prebuild": "npm run clean",
    "build": "tsc -b",
    "start": "./bin/run"
  },
  "dependencies": {
    "@oclif/color": "^1.0.13",
    "@oclif/core": "^4.11.4",
    "@sigstore/mock": "^0.13.0",
    "@tufjs/repo-mock": "^5.0.0",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "oclif": "^4.23.8",
    "tslib": "^2.8.1"
  },
  "oclif": {
    "bin": "server",
    "commands": {
      "strategy": "single",
      "target": "./dist/index.js"
    }
  },
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  }
}
